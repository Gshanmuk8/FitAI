# Frontend build-time config. Copy to `.env` for local dev and set the SAME
# keys in your deploy host (e.g. Vercel → Environment Variables). Vite inlines
# every VITE_* var at BUILD time, so you must redeploy after changing them.

# The deployed backend API base URL — NO trailing slash.
#   Local dev:   http://localhost:4000
#   Production:  https://<your-render-service>.onrender.com   (NOT localhost)
# If this is wrong/empty in a deploy, /api/* calls hit the frontend origin and
# return index.html, producing "Unexpected token '<' ... is not valid JSON".
VITE_API_URL=http://localhost:4000

# Supabase project — same values for local and prod (the anon key is public).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
