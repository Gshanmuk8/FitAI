# FitAI environment template.
# Copy the SERVER block into server/.env and the CLIENT block into
# client/.env, then fill in values. Never commit real keys.

# ============================= SERVER (server/.env) =============================
PORT=
NODE_ENV=

# Postgres connection string (Supabase → Project Settings → Database → URI)
DATABASE_URL=

# Supabase (Project Settings → API). SERVICE key is server-side ONLY.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# AI providers — ALL optional. With none set, the app runs fully on the
# rules engine and static templates.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional Redis for the AI cache (empty = in-memory cache)
REDIS_URL=

# Optional: comma-separated allowed browser origins (empty = allow all; set in production)
CORS_ORIGINS=

# --- AI platform tuning (all optional; defaults in
#     server/src/services/ai/platform/platformConfig.js) ---
AI_PROVIDER_ORDER=
AI_DISABLE_PROVIDERS=
AI_MODEL_GEMINI=
AI_MODEL_OPENAI=
AI_MODEL_ANTHROPIC=
AI_MODEL_OPENROUTER=
AI_MODEL_GROQ=
AI_MODEL_CEREBRAS=
AI_MODEL_CLOUDFLARE=
AI_TEMPERATURE=
AI_MAX_TOKENS=
AI_TIMEOUT_MS=
AI_RETRY_ATTEMPTS=
AI_BREAKER_FAILURES=
AI_BREAKER_OPEN_MS=
AI_BUDGET_DAILY_TOKENS=
AI_BUDGET_DAILY_TOKENS_PER_USER=

# --- Feature flags (all default ON; set to false to disable) ---
FEATURE_REVIEWS=
FEATURE_ACHIEVEMENTS=
FEATURE_ADAPTIVE_PLANNER=
FEATURE_PREFERENCE_LEARNING=
FEATURE_PROGRESS_SNAPSHOTS=

# ============================= CLIENT (client/.env) =============================
# Must be prefixed VITE_ to reach the browser. Use the ANON key here, never
# the service key.
VITE_API_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
